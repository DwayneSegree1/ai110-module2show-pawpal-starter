classDiagram
    %% PawPal+ system design
    %% Keep this file updated so it matches your final implementation.

    class Owner {
        +str name
        +str email
        +List~Pet~ pets
        +dict preferences
        +add_pet(pet) None
        +get_pet(name) Pet
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +Owner owner
        +List~Task~ tasks
        +add_task(task) None
        +remove_task(task) None
        +get_last_completed(task_type) datetime
    }

    class Task {
        +str title
        +TaskType task_type
        +int duration_minutes
        +Priority priority
        +bool recurring
        +datetime last_completed_at
        +TimeWindow preferred_window
        +mark_completed(timestamp) None
    }

    class TaskType {
        <<enumeration>>
        WALK
        FEEDING
        MEDICATION
        GROOMING
        ENRICHMENT
        OTHER
    }

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }

    class TimeWindow {
        +time start_time
        +time end_time
        +contains(t) bool
    }

    class ScheduleConstraints {
        +time day_start
        +time day_end
        +int max_available_minutes
        +dict owner_preferences
    }

    class Scheduler {
        +build_schedule(pet, tasks, constraints) DailyPlan
        +rank_tasks(tasks) List~Task~
        +explain(entry) str
    }

    class DailyPlan {
        +date plan_date
        +Pet pet
        +List~ScheduledTask~ entries
        +add_entry(entry) None
        +total_duration() int
        +summary() str
    }

    class ScheduledTask {
        +Task task
        +time start_time
        +time end_time
        +str reason
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Task --> Priority : has
    Task --> TaskType : categorized by
    Task --> TimeWindow : preferred window
    Scheduler ..> Task : reads
    Scheduler ..> ScheduleConstraints : applies
    Scheduler --> DailyPlan : produces
    DailyPlan "1" --> "*" ScheduledTask : contains
    ScheduledTask --> Task : references
    DailyPlan --> Pet : for
